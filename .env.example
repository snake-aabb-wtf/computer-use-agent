# --- LLM ---
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# --- Agent ---
MAX_STEPS=200
ACTION_DELAY=0.1
REQUEST_TIMEOUT=60

# --- Capture Mode ---
# som = UIA element tree + numbered overlays (recommended, more accurate clicks)
# vision = pure visual screenshot (works with all models)
CAPTURE_MODE=som

# --- Screenshots ---
SCREENSHOT_DIR=screenshots
SCREENSHOT_FORMAT=png

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
